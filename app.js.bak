  orderWebhook: "",
  whatsapp: "213770732262",
  phone: "0770732262",
  currency: "DA"
};

const A = "assets/";
const MENU = {
 burgers:{label:"Smash Burgers",icon:"burger",img:A+"burgers.jpg",items:[
  {id:"b1",n:"Smash Classic",d:"Steak hachÃĐ frais smashÃĐ, cheddar, oignons, pickles, sauce Papa Smash.",p:440},
  {id:"b2",n:"American Smash",d:"Double smash, double cheddar fondu, oignons, sauce amÃĐricaine.",p:540},
  {id:"b3",n:"Smash Pepper",d:"Steak smashÃĐ, sauce poivre crÃĐmeuse, cheddar, oignons.",p:540},
  {id:"b4",n:"Smash Creamy",d:"Steak smashÃĐ, sauce crÃĐmeuse maison, cheddar, cornichons.",p:540},
  {id:"b5",n:"L'IntermÃĐdiaire Smash",d:"Double steak smashÃĐ, cheddar, sauce Papa, oignons croustillants.",p:690,tag:"Best-seller"},
  {id:"b6",n:"Sweet BBQ Smash",d:"Steak smashÃĐ, sauce BBQ, cheddar, oignons croustillants.",p:690},
  {id:"b7",n:"Papa Smash â Le Boss",d:"6 steaks smash premium. L'ultime dÃĐfi, smashed with love.",p:1290,tag:"Le Boss",boss:true}
 ]},
 poulet:{label:"Poulet Burgers",icon:"chicken",img:A+"burgers.jpg",items:[
  {id:"p1",n:"Smash Poulet Crispy",d:"Poulet panÃĐ croustillant, cheddar, salade, sauce blanche.",p:340},
  {id:"p2",n:"Smash Poulet GrillÃĐ",d:"Filet de poulet grillÃĐ, cheddar, salade, sauce maison.",p:340}
 ]},
 pizza:{label:"Pizza Detroit",icon:"pizza",img:A+"pizza.jpg",note:"Prix pizza Ã  confirmer avec le restaurant.",items:[
  {id:"z1",n:"Detroit Poulet",d:"PÃĒte ÃĐpaisse, mozzarella fondante, poulet, sauce crÃĐmeuse, piments.",p:750,confirm:true},
  {id:"z2",n:"Detroit Beef BBQ",d:"PÃĒte ÃĐpaisse, mozzarella, viande hachÃĐe, sauce BBQ.",p:750,confirm:true},
  {id:"z3",n:"Detroit Margherita",d:"PÃĒte ÃĐpaisse, sauce tomate, mozzarella, basilic.",p:600,confirm:true}
 ]},
 supplements:{label:"SupplÃĐments",icon:"plus",img:A+"fries.jpg",items:[
  {id:"s1",n:"Åuf",d:"",p:40},{id:"s2",n:"Camembert",d:"",p:60},{id:"s3",n:"GruyÃĻre",d:"",p:90},
  {id:"s4",n:"Cheddar",d:"",p:80},{id:"s5",n:"Sauce Cheddar",d:"",p:100},{id:"s6",n:"Miel",d:"",p:90},
  {id:"s7",n:"Fromage de chÃĻvre",d:"",p:90},{id:"s8",n:"Mushroom",d:"",p:70},{id:"s9",n:"Bacon de bÅuf",d:"",p:170},
  {id:"s10",n:"Sauce Papa Smash",d:"",p:40}
 ]},
 boissons:{label:"Boissons",icon:"drink",img:A+"shop.jpg",note:"Prix boissons Ã  confirmer.",items:[
  {id:"d1",n:"Canette 33cl",d:"Coca, Fanta, Sprite, Hamoud.",p:120,confirm:true},
  {id:"d2",n:"Eau minÃĐrale 50cl",d:"",p:60,confirm:true},
  {id:"d3",n:"Jus frais",d:"PressÃĐ du jour.",p:250,confirm:true}
 ]}
};
const ICONS={
 burger:'<svg viewBox="0 0 24 24" fill="none"><path d="M4 11c0-3 4-5 8-5s8 2 8 5M4 11h16M5 16h14" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>',
 chicken:'<svg viewBox="0 0 24 24" fill="none"><path d="M6 18c-2 0-3-2-2-4 1-1 1-2 1-4a7 7 0 1114 0c0 2 0 3 1 4 1 2 0 4-2 4z" stroke="currentColor" stroke-width="1.6"/></svg>',
 pizza:'<svg viewBox="0 0 24 24" fill="none"><path d="M12 3l9 18H3z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><circle cx="12" cy="13" r="1.1" fill="currentColor"/><circle cx="9" cy="17" r="1.1" fill="currentColor"/></svg>',
 plus:'<svg viewBox="0 0 24 24" fill="none"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="1.9" stroke-linecap="round"/></svg>',
 drink:'<svg viewBox="0 0 24 24" fill="none"><path d="M7 4h10l-1.2 16H8.2L7 4zM7.5 9h9" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>'
};
const GAL=[A+"burgers.jpg",A+"fries.jpg",A+"pizza.jpg",A+"shop.jpg",A+"board.jpg",A+"hero.jpg",A+"burgers.jpg"];
const fmt=n=>n.toLocaleString('fr-FR');

let activeCat="burgers";
const catsEl=document.getElementById('menuCats'),gridEl=document.getElementById('menuGrid'),noteEl=document.getElementById('menuNote');
function findItem(id){for(const k in MENU){const it=MENU[k].items.find(x=>x.id===id);if(it)return Object.assign({},it,{img:MENU[k].img});}return null;}
function renderCats(){catsEl.innerHTML='';Object.keys(MENU).forEach(k=>{const b=document.createElement('button');
 b.className='cat-btn'+(k===activeCat?' active':'');b.innerHTML=ICONS[MENU[k].icon]+'<span>'+MENU[k].label+'</span>';
 b.onclick=()=>{activeCat=k;renderCats();renderDishes();};catsEl.appendChild(b);});}
function renderDishes(){const c=MENU[activeCat];gridEl.innerHTML='';
 c.items.forEach(it=>{const d=document.createElement('div');d.className='dish reveal';
  const tag=it.tag?'<span class="dish-tag '+(it.boss?'boss':'')+'">'+it.tag+'</span>':'<span></span>';
  d.innerHTML='<img class="dish-thumb" src="'+c.img+'" alt="" loading="lazy">'+
   '<div class="dish-body"><div class="dish-top"><div class="dish-name">'+it.n+'</div>'+
   '<div class="dish-price">'+fmt(it.p)+'<span class="cur"> '+CONFIG.currency+'</span></div></div>'+
   '<div class="dish-desc">'+(it.d||'')+'</div>'+
   '<div class="dish-foot">'+tag+'<button class="add-btn" data-add="'+it.id+'"><svg viewBox="0 0 24 24" fill="none"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/></svg>Ajouter</button></div></div>';
  gridEl.appendChild(d);});
 noteEl.textContent = c.note ? '* '+c.note : '* Tous nos plats sont prÃĐparÃĐs Ã  la commande.';
 observe();}
function renderGallery(){const g=document.getElementById('galGrid');g.innerHTML='';GAL.forEach(u=>{const f=document.createElement('figure');f.innerHTML='<img src="'+u+'" alt="Papa Smash" loading="lazy">';g.appendChild(f);});}
const mqWords=["Smash Burgers","Pizza Detroit","Smashed with love","Ouvert 24/7","Viandes fraÃŪches","Fait maison","Skikda"];
document.getElementById('mq').innerHTML='<b>'+mqWords.join('</b><b>')+'</b><b>'+mqWords.join('</b><b>')+'</b>';

/* ===== CART ===== */
let cart=[];
const overlay=document.getElementById('overlay'),drawer=document.getElementById('cartDrawer');
const cartBody=document.getElementById('cartBody'),cartFoot=document.getElementById('cartFoot'),cartCount=document.getElementById('cartCount');
function cartQty(){return cart.reduce((s,i)=>s+i.q,0);}
function cartTotal(){return cart.reduce((s,i)=>s+i.p*i.q,0);}
function addToCart(id){const it=findItem(id);if(!it)return;const ex=cart.find(c=>c.id===id);
 if(ex)ex.q++;else cart.push({id:it.id,n:it.n,p:it.p,img:it.img,q:1});updateCart();flashBtn(id);}
function flashBtn(id){const b=document.querySelector('[data-add="'+id+'"]');if(b){b.classList.add('added');b.innerHTML='â AjoutÃĐ';setTimeout(()=>{b.classList.remove('added');b.innerHTML='<svg viewBox="0 0 24 24" fill="none"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/></svg>Ajouter';},900);}}
function changeQty(id,d){const c=cart.find(x=>x.id===id);if(!c)return;c.q+=d;if(c.q<=0)cart=cart.filter(x=>x.id!==id);updateCart();}
function updateCart(){cartCount.textContent=cartQty();renderCartBody();}
function renderCartBody(){
 if(!cart.length){cartBody.innerHTML='<div class="cart-empty"><svg viewBox="0 0 24 24" fill="none"><path d="M4 7h16l-1.5 11A2 2 0 0116.5 20h-9A2 2 0 015.5 18L4 7zM8 7a4 4 0 018 0" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg><p>Votre panier est vide.<br>Ajoutez vos burgers prÃĐfÃĐrÃĐs !</p></div>';
  cartFoot.innerHTML='<button class="btn btn-orange checkout-btn" data-goto-menu>Voir le menu</button>';bindFoot();return;}
 cartBody.innerHTML=cart.map(c=>'<div class="cart-item"><img src="'+c.img+'" alt=""><div class="ci-b"><div class="ci-n">'+c.n+'</div><div class="ci-p">'+fmt(c.p)+' '+CONFIG.currency+'</div>'+
  '<div class="qty"><button data-dec="'+c.id+'">â</button><span>'+c.q+'</span><button data-inc="'+c.id+'">+</button></div>'+
  '<button class="ci-rm" data-rm="'+c.id+'">Retirer</button></div></div>').join('');
 cartFoot.innerHTML='<div class="cart-total"><span>Total</span><span class="o">'+fmt(cartTotal())+' '+CONFIG.currency+'</span></div>'+
  '<div class="modes"><label><input type="radio" name="mode" value="Livraison" checked><span>Livraison</span></label><label><input type="radio" name="mode" value="Ã emporter"><span>Ã emporter</span></label></div>'+
  '<div class="field"><label>Nom</label><input id="ckName" placeholder="Votre nom"></div>'+
  '<div class="field"><label>TÃĐlÃĐphone</label><input id="ckPhone" inputmode="tel" placeholder="0770 ..."></div>'+
  '<div class="field" id="addrField"><label>Adresse de livraison</label><input id="ckAddr" placeholder="Quartier, rue..."></div>'+
  '<div class="field"><label>Note (optionnel)</label><textarea id="ckNote" rows="2" placeholder="Sans oignons, sauce Ã  part..."></textarea></div>'+
  '<button class="btn btn-orange checkout-btn" id="placeOrder"><svg viewBox="0 0 24 24" fill="none"><path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>Passer la commande</button>';
 bindFoot();
 const addr=cartFoot.querySelector('#addrField');
 cartFoot.querySelectorAll('input[name=mode]').forEach(r=>r.onchange=()=>{addr.style.display=cartFoot.querySelector('input[name=mode]:checked').value==='Livraison'?'block':'none';});
 cartFoot.querySelector('#placeOrder').onclick=placeOrder;
}
function bindFoot(){cartFoot.querySelectorAll('[data-goto-menu]').forEach(b=>b.onclick=()=>{closeCart();document.getElementById('menu').scrollIntoView();});}
function openCart(){overlay.classList.add('open');drawer.classList.add('open');document.body.style.overflow='hidden';}
function closeCart(){overlay.classList.remove('open');drawer.classList.remove('open');document.body.style.overflow='';}

function placeOrder(){
 const name=(document.getElementById('ckName').value||'').trim();
 const phone=(document.getElementById('ckPhone').value||'').trim();
 const mode=cartFoot.querySelector('input[name=mode]:checked').value;
 const addrEl=document.getElementById('ckAddr');
 const addr=(addrEl?addrEl.value:'').trim();
 const note=(document.getElementById('ckNote').value||'').trim();
 if(!name||!phone){alert("Merci d'indiquer votre nom et tÃĐlÃĐphone.");return;}
 if(mode==='Livraison'&&!addr){alert("Merci d'indiquer l'adresse de livraison.");return;}
 const order={
   restaurant:"Papa Smash Skikda",
   items:cart.map(c=>({id:c.id,nom:c.n,prix:c.p,quantite:c.q})),
   total:cartTotal(),devise:CONFIG.currency,
   client:{nom:name,telephone:phone,adresse:addr||null},
   mode:mode,note:note||null,date:new Date().toISOString()
 };
 if(CONFIG.orderWebhook){
   fetch(CONFIG.orderWebhook,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(order)})
     .then(()=>showOrderOk(order)).catch(()=>{sendWhatsApp(order);showOrderOk(order);});
 } else {
   sendWhatsApp(order);showOrderOk(order);
 }
}
function orderText(o){
 let t='*Nouvelle commande â Papa Smash*%0A%0A';
 o.items.forEach(i=>{t+='âĒ '+i.quantite+'Ã '+i.nom+' â '+fmt(i.prix*i.quantite)+' '+o.devise+'%0A';});
 t+='%0A*Total : '+fmt(o.total)+' '+o.devise+'*%0A%0A';
 t+='Mode : '+o.mode+'%0A'+'Nom : '+o.client.nom+'%0A'+'TÃĐl : '+o.client.telephone+'%0A';
 if(o.client.adresse)t+='Adresse : '+o.client.adresse+'%0A';
 if(o.note)t+='Note : '+o.note+'%0A';
 return t;
}
function sendWhatsApp(o){window.open('https://wa.me/'+CONFIG.whatsapp+'?text='+orderText(o),'_blank');}
function showOrderOk(o){
 cartBody.innerHTML='<div class="order-ok"><div class="ok-ic"><svg viewBox="0 0 24 24" fill="none"><path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg></div>'+
  '<h4>Commande envoyÃĐe !</h4><p>Merci '+o.client.nom+' ð<br>Total : <b>'+fmt(o.total)+' '+o.devise+'</b><br>On vous rappelle au '+o.client.telephone+' pour confirmer.</p></div>';
 cartFoot.innerHTML='<button class="btn btn-orange checkout-btn" id="newOrder">Nouvelle commande</button>';
 cart=[];cartCount.textContent='0';
 cartFoot.querySelector('#newOrder').onclick=()=>{closeCart();updateCart();};
}

document.addEventListener('click',e=>{
 const add=e.target.closest('[data-add]');if(add){addToCart(add.dataset.add);return;}
 if(e.target.closest('[data-open-cart]')){openCart();return;}
 if(e.target.closest('[data-open-menu]')){document.getElementById('menu').scrollIntoView();return;}
 if(e.target.closest('[data-goto-pizza]')){activeCat='pizza';renderCats();renderDishes();document.getElementById('menu').scrollIntoView();return;}
 const inc=e.target.closest('[data-inc]');if(inc){changeQty(inc.dataset.inc,1);return;}
 const dec=e.target.closest('[data-dec]');if(dec){changeQty(dec.dataset.dec,-1);return;}
 const rm=e.target.closest('[data-rm]');if(rm){cart=cart.filter(x=>x.id!==rm.dataset.rm);updateCart();return;}
});
document.getElementById('cartClose').onclick=closeCart;
overlay.onclick=closeCart;

/* ===== CHATBOT ===== */
const chatBody=document.getElementById('chatBody'),chatChips=document.getElementById('chatChips');
const CHIPS=["Voir le menu","Prix des burgers","Pizza Detroit","Horaires","OÃđ vous trouver","Livraison ?","Commander"];
function botSay(html){const m=document.createElement('div');m.className='msg bot';m.innerHTML=html;chatBody.appendChild(m);chatBody.scrollTop=chatBody.scrollHeight;}
function userSay(t){const m=document.createElement('div');m.className='msg user';m.textContent=t;chatBody.appendChild(m);chatBody.scrollTop=chatBody.scrollHeight;}
function renderChips(){chatChips.innerHTML='';CHIPS.forEach(c=>{const b=document.createElement('button');b.className='chip';b.textContent=c;b.onclick=()=>handle(c);chatChips.appendChild(b);});}
function botReply(q){
 const t=q.toLowerCase();
 if(/menu|carte|manger|propos/.test(t))return 'Voici nos catÃĐgories : <b>Smash Burgers</b>, <b>Poulet Burgers</b>, <b>Pizza Detroit</b>, SupplÃĐments et Boissons. Cliquez sur ÂŦ Voir le menu Âŧ ð ou ajoutez directement au panier !';
 if(/prix|combien|tarif|cout|coÃŧt/.test(t))return 'Nos burgers vont de <b>440 DA</b> (Smash Classic) Ã  <b>1290 DA</b> (Papa Smash â Le Boss ðĨ). Poulet burgers Ã  <b>340 DA</b>. SupplÃĐments dÃĻs 40 DA.';
 if(/pizza|detroit/.test(t))return 'Notre <b>Pizza Detroit</b> ð : pÃĒte ÃĐpaisse croustillante dehors, moelleuse dedans, fromage fondant. Format 10Ã30 cm. Dispo en Poulet, Beef BBQ ou Margherita.';
 if(/horaire|ouvert|heure|ferm/.test(t))return 'On est ouvert <b>24h/24, 7j/7</b> â° â Ã  toute heure, on smash pour vous !';
 if(/oÃđ|adresse|trouver|situ|skikda|localis|map/.test(t))return 'On est Ã  <b>Skikda</b> (plus code VWJ4+MP8). ð Cliquez sur ÂŦ Nous trouver Âŧ pour l\'itinÃĐraire Google Maps.';
 if(/livr|deliver|emporter|domicile/.test(t))return 'Oui â <b>Livraison</b> et <b>Ã  emporter</b>. Ajoutez vos plats au panier, choisissez le mode et validez â on vous rappelle pour confirmer.';
 if(/command|panier|acheter|order/.test(t)){setTimeout(openCart,400);return 'Parfait ! J\'ouvre votre panier ð. Ajoutez vos plats depuis le menu puis ÂŦ Passer la commande Âŧ.';}
 if(/halal/.test(t))return 'Oui, <b>100% halal</b> et viandes fraÃŪches prÃĐparÃĐes Ã  la commande. ð';
 if(/tel|tÃĐlÃĐphone|numero|numÃĐro|appel|contact/.test(t))return 'Appelez-nous au <b>0770 73 22 62</b> ð â ouvert 24h/24.';
 if(/bonjour|salut|hello|cc|coucou|salam/.test(t))return 'Bonjour et bienvenue chez <b>Papa Smash</b> ð ! Comment puis-je vous aider ?';
 if(/merci|thanks|cool|super|top/.test(t))return 'Avec plaisir ð Bon appÃĐtit chez Papa Smash !';
 return 'Je peux vous renseigner sur le <b>menu</b>, les <b>prix</b>, la <b>pizza</b>, les <b>horaires</b>, la <b>livraison</b> ou vous aider Ã  <b>commander</b>. Ou appelez le <b>0770 73 22 62</b> ð';
}
function handle(q){userSay(q);
 if(/voir le menu/i.test(q))document.getElementById('menu').scrollIntoView();
 setTimeout(()=>botSay(botReply(q)),350);}
const chatPanel=document.getElementById('chatPanel');
function openChat(){chatPanel.classList.add('open');if(!chatBody.dataset.init){chatBody.dataset.init=1;
 botSay('ð Salut ! Je suis <b>Papa Bot</b>. Burgers smash, pizza Detroit, ouvert 24h/24. Que voulez-vous savoir ?');renderChips();}}
document.getElementById('chatFab').onclick=()=>chatPanel.classList.contains('open')?chatPanel.classList.remove('open'):openChat();
document.getElementById('chatClose').onclick=()=>chatPanel.classList.remove('open');
document.getElementById('chatForm').onsubmit=e=>{e.preventDefault();const i=document.getElementById('chatInput');const v=i.value.trim();if(!v)return;i.value='';handle(v);};

/* ===== NAV / INIT ===== */
const navLeft=document.getElementById('navLeft');
document.getElementById('menuToggle').onclick=()=>navLeft.classList.toggle('open');
navLeft.querySelectorAll('a').forEach(a=>a.onclick=()=>navLeft.classList.remove('open'));
window.addEventListener('load',()=>document.querySelector('.hero').classList.add('in'));
setTimeout(()=>document.querySelector('.hero').classList.add('in'),120);
let io;function observe(){if(!io){io=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('show');io.unobserve(e.target);}}),{threshold:.12});}
 document.querySelectorAll('.reveal:not(.show)').forEach(el=>io.observe(el));}
document.getElementById('bannerA').style.backgroundImage="url('"+A+"fries.jpg')";
document.getElementById('yr').textContent=new Date().getFullYear();
renderCats();renderDishes();renderGallery();observe();updateCart();
